# Example Compositfile — nuetzliche workspace
#
# This is a governance document, not an inventory.
# It declares what SHOULD be true: policies, contracts, trust rules, budgets.
# The inventory of what EXISTS is in composit-report.yaml (generated by `composit scan`).
# Drift detection compares this file against the report.

workspace "nuetzliche" {

  # --- Approved Providers ---
  # Only these providers may be used by agents in this workspace.

  provider "croniq" {
    manifest  "https://composit.nuetzliche.it/.well-known/composit.json"
    trust     "contract"
    compliance ["gdpr", "eu-ai-act"]
  }

  provider "hookaido" {
    manifest  "https://hooks.nuetzliche.it/.well-known/composit.json"
    trust     "contract"
  }

  provider "powerbrain" {
    manifest  "https://mcp.nuetzliche.it/.well-known/composit.json"
    trust     "contract"
    compliance ["gdpr", "eu-ai-act"]
  }

  # --- Budget Constraints ---

  budget "workspace" {
    max_monthly  "500 EUR"
    alert_at     "80%"
  }

  budget "per-agent-session" {
    max_monthly  "50 EUR"
  }

  # --- Policies ---

  policy "agent-limits" {
    source "policies/agent-limits.rego"
    description "Max jobs, channels, and resources per agent session"
  }

  policy "provider-approval" {
    source "policies/provider-approval.rego"
    description "Only approved providers may be provisioned"
  }

  policy "data-residency" {
    source "policies/data-residency.rego"
    description "All data must remain in EU regions"
  }
}
