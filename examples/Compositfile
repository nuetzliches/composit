# Example Compositfile — nuetzliche workspace
#
# This is a governance document, not an inventory.
# It declares what SHOULD be true: approved providers, budgets, resource
# constraints, and policy references.
# The inventory of what EXISTS is in composit-report.yaml (generated by `composit scan`).
# Drift detection (`composit diff`) compares this file against the report.

workspace "nuetzliche" {

  # --- Approved Providers ---
  # Only these providers may be used in this workspace.
  # Any provider found in the scan report that is not listed here
  # will be flagged as a governance violation.
  #
  # Trust levels (RFC 002):
  # - "public":   only the unauthenticated .well-known manifest is read.
  # - "contract": composit also fetches the authenticated contract
  #               manifest, using the credential named in `auth { env }`.

  provider "croniq" {
    manifest   = "https://nuetzliche.it/.well-known/composit.json"
    trust      = "contract"
    compliance = ["gdpr", "eu-ai-act"]
    auth {
      type = "api-key"
      env  = "NUETZLICHE_COMPOSIT_KEY"
    }
  }

  provider "hookaido" {
    manifest = "https://nuetzliche.it/.well-known/composit.json"
    trust    = "contract"
    auth {
      type = "api-key"
      env  = "NUETZLICHE_COMPOSIT_KEY"
    }
  }

  provider "powerbrain" {
    manifest   = "https://nuetzliche.it/.well-known/composit.json"
    trust      = "contract"
    compliance = ["gdpr", "eu-ai-act"]
    auth {
      type = "api-key"
      env  = "NUETZLICHE_COMPOSIT_KEY"
    }
  }

  # --- Budget Constraints ---
  # Compared against estimated_monthly_cost from the scan report.

  budget "workspace" {
    max_monthly = "500 EUR"
    alert_at    = "80%"
  }

  budget "per-agent-session" {
    max_monthly = "50 EUR"
  }

  # --- Resource Constraints ---
  # Controls which resource types are allowed and in what quantities.
  # If at least one `allow` block exists, unlisted types are violations (allowlist mode).
  # If no `allow` blocks exist, all types are implicitly allowed.

  resources {
    max_total = 200

    allow "docker_compose" {
      max = 15
    }

    allow "docker_service" {
      max = 50
    }

    allow "dockerfile" {
      max = 20
    }

    allow "env_file" {
      max = 30
    }

    allow "terraform_config" {
      max = 10
    }

    allow "terraform_resource" {
      max = 100
    }

    allow "terraform_module" {
      max = 20
    }

    allow "workflow" {
      max = 30
    }

    allow "caddyfile" {
      max = 10
    }

    allow "caddy_site" {
      max = 30
    }

    allow "prometheus_config" {
      max = 5
    }

    allow "prometheus_rules" {
      max = 10
    }

    allow "cron_job" {
      max = 20
    }

    allow "mcp_server" {
      max = 10
    }

    # Required resources — these MUST exist in the scan report.
    require "docker_compose" {
      min = 1
    }
  }

  # --- Policies ---
  # References to OPA/Rego policy files. composit diff checks if the files exist.
  # Actual policy evaluation requires OPA integration (future).

  policy "agent-limits" {
    source      = "policies/agent-limits.rego"
    description = "Max jobs, channels, and resources per agent session"
  }

  policy "provider-approval" {
    source      = "policies/provider-approval.rego"
    description = "Only approved providers may be provisioned"
  }

  policy "data-residency" {
    source      = "policies/data-residency.rego"
    description = "All data must remain in EU regions"
  }
}
