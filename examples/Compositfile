# Example Compositfile — nuetzliche workspace
#
# This is a visibility document, not a deployment tool.
# It declares what exists, why, and how it connects.

workspace "nuetzliche" {

  # --- Providers ---

  provider "croniq" {
    endpoint  "https://croniq.nuetzliche.it"
    manifest  "https://composit.nuetzliche.it/.well-known/composit.json"
    protocol  "mcp"
    capabilities ["scheduling"]
  }

  provider "hookaido" {
    endpoint  "https://hooks.nuetzliche.it"
    protocol  "mcp"
    capabilities ["events"]
  }

  provider "powerbrain" {
    endpoint  "https://mcp.nuetzliche.it/powerbrain"
    protocol  "mcp"
    capabilities ["knowledge"]
    compliance ["gdpr", "eu-ai-act"]
  }

  # --- Business Cases ---

  business_case "pr-review-bot" {
    description "Automated PR review with context from codebase knowledge"

    uses {
      croniq     { jobs ["pr-review-daily"] }
      hookaido   { channels ["github-pr-events"] }
      powerbrain { collections ["pb_code"] }
    }

    created   "2026-03-15"
    owner     "agent:claude-code"
    approved  "sebastian"
    budget    "50 EUR/month"
    tags      ["engineering", "automation"]
  }

  business_case "webhook-mirror-sync" {
    description "Mirror GitHub repos to internal Forgejo"

    uses {
      hookaido { channels ["github-push-forgejo"] }
    }

    created  "2026-01-10"
    owner    "sebastian"
    budget   "0 EUR/month"
    tags     ["devops", "git"]
  }

  # --- Policies ---

  policy "agent-limits" {
    source "policies/agent-limits.rego"
  }

  policy "provider-approval" {
    source "policies/provider-approval.rego"
  }
}
