# Compositfile — reviewed SHOULD-state of this workspace.
#
# AGENT INSTRUCTIONS: Do not modify this file unless the user explicitly
# asks. This file is human-reviewed governance. When you change the
# repo's infrastructure (docker-compose, workflows, terraform, env
# files), leave this file alone — `composit diff` will surface the drift
# for the user to decide whether the Compositfile should follow.
# Silently updating the Compositfile defeats its purpose.

# Composit Compositfile — the CLI project's own governance.
#
# Self-hosting proof: `composit scan + diff` runs on this repo in CI.
# Everything composit needs to know — governance AND scan tuning — lives
# here in one reviewed HCL file. There is no separate composit.config.yaml.
#
# Current scan baseline (2026-04-21):
#   2 workflows — ci.yml (cargo fmt/test gate) and pages.yml (docs site).
#   No docker services, no providers, no env files.

workspace "composit" {

  # --- Scan Tuning ---
  # Test fixtures under tests/fixtures/ and the synthetic demo workspaces
  # under examples/demo-drift/ are part of the test suite, not of the
  # project's real infrastructure. Exclude them so the inventory reflects
  # what composit itself deploys.

  scan {
    exclude = [
      "tests/fixtures",
      "examples",
    ]
  }

  # --- Approved Providers ---
  # The CLI itself consumes no providers. Empty-but-present declares intent:
  # anything that surfaces here in future scans is unapproved by default.

  # (no provider blocks)

  # --- Resource Constraints ---
  # Calibrated to the actual scan — slack kept tight because new infra in
  # a CLI-only project deserves an explicit Compositfile update.

  resources {
    max_total = 10

    allow "workflow" {
      max = 4
    }

    allow "dockerfile" {
      max = 2
    }

    # The CLI is itself a Rust crate — own Cargo.toml.
    allow "cargo_crate" {
      max = 2
    }

    # CI is mandatory. If ci.yml disappears from a PR, `composit diff --strict`
    # fails and the PR cannot merge.
    require "workflow" {
      min = 1
    }
  }
}
